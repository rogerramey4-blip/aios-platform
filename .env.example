# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-random-32-char-string

# ── Encryption at rest (AES-256 via Fernet HKDF) ────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── SMTP for OTP delivery ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# ── Hosting / custom domain routing ──────────────────────────────────────────
APP_HOSTNAME=your-app.railway.app

# ── AI (for document classification) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (defaults to aios_tenants.db in project root) ───────────────────
TENANT_DB_PATH=aios_tenants.db
